# Git ignore rules for Python tooling, local environment files, and extractor runtime artifacts.
# Python cache and build artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.pytest_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/

# Local env files
.env
.env.*

# Tooling caches
.pipeline_qa_cache/

# Local output artifacts
output/

# OS/editor noise
.DS_Store
.vscode/
.idea/
