# MongoDB Atlas Sandbox connection
conn_string=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
username=USER
mongo_db_pass=PASSWORD
MONGO_DB_NAME=qa_agent

# AWS (Bedrock + Athena + Glue) — defaults below match the smart meter pipeline's terraform
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Bedrock
USE_BEDROCK=1
BEDROCK_MODEL=anthropic.claude-sonnet-4-5-20250929-v2:0

# Anthropic direct (used only if USE_BEDROCK=0)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Glue / Athena — pulled from energy-smart-meter-pipeline/terraform
GLUE_DATABASE=energy_smart_meter
ATHENA_DATABASE=energy_smart_meter
ATHENA_WORKGROUP=energy-smart-meter-pipeline-dev-athena
ATHENA_OUTPUT_LOCATION=s3://smart-meter-athena-results/
ATHENA_TIMEOUT_SEC=30
ATHENA_MAX_BYTES=209715200
ATHENA_MAX_ROWS=100

# Voyage embeddings (the M10 sandbox supplies a key, or sign up free)
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3

# LangSmith (optional)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=data-qa-agent
langsmith_token=

# Loop control
MAX_ITERATIONS=2
